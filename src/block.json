  "name": "phclb/cards-layout",
  "version": "2.0.2",
  "title": "Cards Layout",
  "category": "widgets",
  "description": "Build responsive, customizable card components with multiple layouts and dynamic styles in the Gutenberg editor.",
  "keywords": [
    "cards",
    "layout",
    "content",
    "gallery",
    "lightbox"
  ],
  "textdomain": "cards-layout",
